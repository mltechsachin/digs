"""GPU-friendly QLoRA fine-tuning script.

Usage (example):
  python3 code/sft/train_qlora.py \
    --base_model Qwen/Qwen2.5-7B-Instruct \
    --train_data data/sft_train.jsonl \
    --val_data data/sft_val.jsonl \
    --output_dir outputs/qlora

This script expects:
- transformers
- peft
- bitsandbytes
- datasets
- torch with CUDA support
"""

import argparse
import json


def load_jsonl(path):
    rows = []
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            rows.append(json.loads(line))
    return rows


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--base_model", default="Qwen/Qwen2.5-7B-Instruct")
    parser.add_argument("--train_data", default="data/sft_train.jsonl")
    parser.add_argument("--val_data", default="data/sft_val.jsonl")
    parser.add_argument("--output_dir", default="outputs/qlora")
    parser.add_argument("--max_length", type=int, default=512)
    parser.add_argument("--epochs", type=float, default=2)
    parser.add_argument("--learning_rate", type=float, default=2e-4)
    parser.add_argument("--train_batch_size", type=int, default=1)
    parser.add_argument("--eval_batch_size", type=int, default=1)
    parser.add_argument("--gradient_accumulation_steps", type=int, default=8)
    parser.add_argument("--save_steps", type=int, default=50)
    parser.add_argument("--eval_steps", type=int, default=50)
    parser.add_argument("--logging_steps", type=int, default=1)
    parser.add_argument("--lora_r", type=int, default=8)
    parser.add_argument("--lora_alpha", type=int, default=16)
    parser.add_argument("--lora_dropout", type=float, default=0.05)
    cli_args = parser.parse_args()

    # Lazy imports so the script can be inspected without deps installed
    import torch
    from datasets import Dataset
    import time
    from transformers import (
        AutoTokenizer,
        AutoModelForCausalLM,
        TrainingArguments,
        Trainer,
        BitsAndBytesConfig,
        DataCollatorForLanguageModeling,
        TrainerCallback,
    )
    from peft import LoraConfig, get_peft_model, prepare_model_for_kbit_training

    if not torch.cuda.is_available():
        raise RuntimeError(
            "QLoRA training requires a CUDA GPU. No CUDA device was detected."
        )

    compute_dtype = torch.bfloat16 if torch.cuda.is_bf16_supported() else torch.float16
    precision_name = "bf16" if compute_dtype == torch.bfloat16 else "fp16"
    gpu_name = torch.cuda.get_device_name(0)
    print(f"Using CUDA GPU: {gpu_name} with {precision_name} compute", flush=True)

    train_rows = load_jsonl(cli_args.train_data)
    val_rows = load_jsonl(cli_args.val_data)

    def format_row(row):
        prompt = row["user"]
        completion = row["assistant"]
        return {"text": f"User: {prompt}\nAssistant: {completion}"}

    train_ds = Dataset.from_list([format_row(r) for r in train_rows])
    val_ds = Dataset.from_list([format_row(r) for r in val_rows])

    tokenizer = AutoTokenizer.from_pretrained(cli_args.base_model, use_fast=True)
    if tokenizer.pad_token is None:
        tokenizer.pad_token = tokenizer.eos_token
    tokenizer.padding_side = "right"
    bnb_config = BitsAndBytesConfig(
        load_in_4bit=True,
        bnb_4bit_compute_dtype=compute_dtype,
        bnb_4bit_use_double_quant=True,
        bnb_4bit_quant_type="nf4",
    )
    model = AutoModelForCausalLM.from_pretrained(
        cli_args.base_model,
        quantization_config=bnb_config,
        device_map="auto",
        torch_dtype=compute_dtype,
        low_cpu_mem_usage=True,
    )
    model.config.use_cache = False
    model = prepare_model_for_kbit_training(model)
    model.gradient_checkpointing_enable(gradient_checkpointing_kwargs={"use_reentrant": False})

    lora_config = LoraConfig(
        r=cli_args.lora_r,
        lora_alpha=cli_args.lora_alpha,
        lora_dropout=cli_args.lora_dropout,
        target_modules=["q_proj", "k_proj", "v_proj", "o_proj"],
        bias="none",
        task_type="CAUSAL_LM",
    )

    model = get_peft_model(model, lora_config)
    model.print_trainable_parameters()

    def tokenize(batch):
        encoded = tokenizer(batch["text"], truncation=True, max_length=cli_args.max_length)
        encoded["labels"] = encoded["input_ids"].copy()
        return encoded

    train_ds = train_ds.map(tokenize, batched=True, remove_columns=["text"])
    val_ds = val_ds.map(tokenize, batched=True, remove_columns=["text"])

    train_args = TrainingArguments(
        output_dir=cli_args.output_dir,
        per_device_train_batch_size=cli_args.train_batch_size,
        per_device_eval_batch_size=cli_args.eval_batch_size,
        gradient_accumulation_steps=cli_args.gradient_accumulation_steps,
        num_train_epochs=cli_args.epochs,
        learning_rate=cli_args.learning_rate,
        eval_strategy="steps",
        eval_steps=cli_args.eval_steps,
        save_strategy="steps",
        save_steps=cli_args.save_steps,
        logging_steps=cli_args.logging_steps,
        logging_first_step=True,
        disable_tqdm=False,
        bf16=compute_dtype == torch.bfloat16,
        fp16=compute_dtype == torch.float16,
        gradient_checkpointing=True,
        gradient_checkpointing_kwargs={"use_reentrant": False},
        remove_unused_columns=False,
        dataloader_pin_memory=True,
        save_total_limit=2,
        report_to="none",
    )
    print("starting data collator", flush=True)
    data_collator = DataCollatorForLanguageModeling(tokenizer=tokenizer, mlm=False)

    class ProgressCallback(TrainerCallback):
        def __init__(self):
            self.start_time = time.time()

        def on_log(self, args, state, control, logs=None, **kwargs):
            if not logs:
                return
            elapsed = time.time() - self.start_time
            step = state.global_step
            msg = f"[train] step={step} elapsed={elapsed:.1f}s"
            if "loss" in logs:
                msg += f" loss={logs['loss']:.4f}"
            if "learning_rate" in logs:
                msg += f" lr={logs['learning_rate']:.2e}"
            print(msg, flush=True)

        def on_step_end(self, args, state, control, **kwargs):
            # Lightweight progress line even if tqdm is suppressed by the terminal
            elapsed = time.time() - self.start_time
            max_steps = state.max_steps or 0
            if max_steps:
                pct = 100.0 * state.global_step / max_steps
                print(f"[progress] {state.global_step}/{max_steps} ({pct:.1f}%) elapsed={elapsed:.1f}s", flush=True)

    print("starting trainer", flush=True)
    trainer = Trainer(
        model=model,
        args=train_args,
        train_dataset=train_ds,
        eval_dataset=val_ds,
        data_collator=data_collator,
        callbacks=[ProgressCallback()],
    )
    print("starting train", flush=True)
    trainer.train()
    trainer.save_model(cli_args.output_dir)
    tokenizer.save_pretrained(cli_args.output_dir)


if __name__ == "__main__":
    main()
