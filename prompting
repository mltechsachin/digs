def build_prompt(user_text, include_few_shot=True):
    prompt = SYSTEM_PROMPT
    if include_few_shot:
        for ex in FEW_SHOT_EXAMPLES:
            prompt += "User: " + ex["user"] + "\n"
            prompt += "Assistant: " + json_dumps_compact(ex["assistant_json"]) + "\n\n"
    prompt += "User: " + user_text + "\n"
    prompt += "Assistant:"
    return prompt


def json_dumps_compact(obj):
    import json
    return json.dumps(obj, ensure_ascii=True, separators=(",", ":"))
